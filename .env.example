# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/portfolio_db?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=                        # openssl rand -base64 32
NEXT_PUBLIC_SITE_URL=https://your-domain.com

BLOG_ADMIN_EMAIL=admin@example.com
BLOG_ADMIN_PASSWORD=change-me-please
ADMIN_ENTRY_PATH=/control

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth App (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── S3 / CloudFront ─────────────────────────────────────────────────────────
AWS_S3_BUCKET=portfolio-images-xxxxxxxxx
AWS_S3_REGION=us-east-1
AWS_CLOUDFRONT_DOMAIN=xxxxxxxxxxxx.cloudfront.net   # media CDN (not Amplify)

# ─── AWS credentials — choose ONE strategy ───────────────────────────────────
#
#  Strategy A: Amplify execution role (zero keys — recommended for Amplify)
#    Leave all credential vars below unset. Attach an inline s3:PutObject
#    policy to your AmplifyServiceRole in IAM.
#
#  Strategy B: Vercel OIDC (recommended for Vercel — zero keys)
#    AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/VercelPortfolioS3Role
#    VERCEL_OIDC_TOKEN is injected automatically by Vercel — do NOT set it.
#
#  Strategy C: Scoped app IAM user (local dev / last resort)
#    S3_UPLOADER_KEY_ID=AKIA...
#    S3_UPLOADER_SECRET=...
#    The user's policy must include the S3 actions below plus ses:SendEmail on
#    both the verified SES identity and the configured SES configuration set.
#
# Uncomment whichever applies:
# AWS_ROLE_ARN=
# S3_UPLOADER_KEY_ID=
# S3_UPLOADER_SECRET=
#
# NOTE: media GC (tag on save, delete on remove, and the reconciliation sweep)
# needs an IAM policy broader than PutObject — see aws/iam-uploader-policy.json:
#   s3:PutObject, s3:PutObjectTagging, s3:GetObject, s3:DeleteObject, s3:ListBucket
# on uploads/* and media/*. Uploads will 403 until PutObjectTagging is granted.

# ─── Media reconciliation sweep (Vercel Cron) ────────────────────────────────
# Secret Vercel Cron sends as `Authorization: Bearer $CRON_SECRET` to
# /api/admin/media/sweep. Also accepted for a manual POST trigger.
CRON_SECRET=                            # openssl rand -hex 32

# ─── Transactional email (Amazon SES) ────────────────────────────────────────
# Contact form (/api/contact) + newsletter double-opt-in (/api/newsletter/*)
# send via SES, using the SAME AWS credential chain as S3 (Vercel OIDC role in
# prod — no API key). The From domain must be a verified SES identity.
EMAIL_FROM=Victor Nabasu <noreply@nerosiegfried.com>   # must be an SES-verified sender
CONTACT_TO=victornabasu@yahoo.com                      # where contact messages are delivered
AWS_SES_REGION=us-east-1                                # SES region (defaults to AWS_S3_REGION)
SES_CONFIGURATION_SET=portfolio-email                  # bounce/complaint event tracking

# ─── Cloudflare Turnstile (spam protection: contact + newsletter) ────────────
# Site key is public (widget); secret verifies server-side. If the secret is
# unset the check is skipped (honeypot + per-IP rate limiting still apply).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
