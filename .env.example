# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/portfolio_db?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=                        # openssl rand -base64 32
NEXT_PUBLIC_SITE_URL=https://your-domain.com

BLOG_ADMIN_EMAIL=admin@example.com
BLOG_ADMIN_PASSWORD=change-me-please
ADMIN_ENTRY_PATH=/control

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth App (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── S3 / CloudFront ─────────────────────────────────────────────────────────
AWS_S3_BUCKET=portfolio-images-xxxxxxxxx
AWS_S3_REGION=us-east-1
AWS_CLOUDFRONT_DOMAIN=xxxxxxxxxxxx.cloudfront.net   # media CDN (not Amplify)

# ─── AWS credentials — choose ONE strategy ───────────────────────────────────
#
#  Strategy A: Amplify execution role (zero keys — recommended for Amplify)
#    Leave all credential vars below unset. Attach an inline s3:PutObject
#    policy to your AmplifyServiceRole in IAM.
#
#  Strategy B: Vercel OIDC (recommended for Vercel — zero keys)
#    AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/VercelPortfolioS3Role
#    VERCEL_OIDC_TOKEN is injected automatically by Vercel — do NOT set it.
#
#  Strategy C: Scoped IAM user (local dev / last resort)
#    S3_UPLOADER_KEY_ID=AKIA...
#    S3_UPLOADER_SECRET=...
#
# Uncomment whichever applies:
# AWS_ROLE_ARN=
# S3_UPLOADER_KEY_ID=
# S3_UPLOADER_SECRET=
