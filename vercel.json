{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "blog.nerosiegfried.com" }],
      "destination": "https://nerosiegfried.com/blog",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "blog.nerosiegfried.com" }],
      "destination": "https://nerosiegfried.com/blog/:path*",
      "permanent": true
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
