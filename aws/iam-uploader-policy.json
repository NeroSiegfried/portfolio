{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MediaObjectReadWriteTagDelete",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectTagging",
        "s3:GetObject",
        "s3:GetObjectTagging",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::BUCKET/uploads/*",
        "arn:aws:s3:::BUCKET/media/*"
      ]
    },
    {
      "Sid": "MediaListForSweep",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": ["arn:aws:s3:::BUCKET"],
      "Condition": {
        "StringLike": { "s3:prefix": ["uploads/*", "media/*"] }
      }
    },
    {
      "Sid": "TransactionalEmailSend",
      "Effect": "Allow",
      "Action": ["ses:SendEmail"],
      "Resource": [
        "arn:aws:ses:us-east-1:ACCOUNT_ID:identity/nerosiegfried.com",
        "arn:aws:ses:us-east-1:ACCOUNT_ID:identity/victornabasu@yahoo.com",
        "arn:aws:ses:us-east-1:ACCOUNT_ID:configuration-set/portfolio-email"
      ]
    }
  ]
}
